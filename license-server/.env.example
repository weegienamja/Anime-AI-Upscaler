# Patreon OAuth credentials (NEVER share or ship in desktop app)
PATREON_CLIENT_ID=your_patreon_client_id
PATREON_CLIENT_SECRET=your_patreon_client_secret
PATREON_CAMPAIGN_ID=your_campaign_id

# Patreon redirect URI — must match Patreon app settings
PATREON_REDIRECT_URI=https://your-domain.com/auth/callback

# JWT signing keys
JWT_SECRET=generate_a_strong_random_secret_here
REFRESH_TOKEN_SECRET=generate_another_strong_random_secret

# Server
PORT=3500
BASE_URL=https://your-domain.com

# Desktop app deep link scheme
APP_SCHEME=animeupscaler

# Entitlement durations (seconds)
ENTITLEMENT_TTL=604800
OFFLINE_GRACE_SECONDS=259200
